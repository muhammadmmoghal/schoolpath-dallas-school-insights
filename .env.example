# Supabase credentials for scripts/load_supabase.py
# Copy this file to .env and fill in real values.
# .env is git-ignored; never commit real secrets.

# Project API URL  (Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role secret key  (Settings → API → service_role)
# This key bypasses RLS and is required to INSERT/DELETE rows.
# Do NOT use the anon key here.
SUPABASE_SERVICE_KEY=your-service-role-key-here
